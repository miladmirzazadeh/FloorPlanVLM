# Copy to .env and fill in (or set these as RunPod template environment variables).
# Only HF_TOKEN and HF_USER are required.

# REQUIRED -------------------------------------------------------------------
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx   # https://huggingface.co/settings/tokens (write)
HF_USER=miladmirzazadeh                          # your HF username -> repos: <user>/floorplan-vlm-sft / -grpo

# OPTIONAL -------------------------------------------------------------------
# SMOKE_TEST=1            # tiny 40-sample run to validate the whole loop cheaply first
# MODEL_ID=Qwen/Qwen2.5-VL-3B-Instruct
# PRIVATE_REPOS=true      # set false to make the HF checkpoint repos public
# RUN_GRPO=true           # set false to stop after SFT

# Explicit repo overrides (otherwise derived from HF_USER)
# HF_REPO_SFT=miladmirzazadeh/floorplan-vlm-sft
# HF_REPO_GRPO=miladmirzazadeh/floorplan-vlm-grpo

# Put the persistent volume in front so checkpoints survive pod stop/restart:
# DATA_DIR=/workspace/cubicasa_data
# OUTPUT_DIR_SFT=/workspace/outputs/sft
# OUTPUT_DIR_GRPO=/workspace/outputs/grpo

# Hyperparameter overrides (defaults reproduce the paper recipe at public-data scale)
# MAX_SAMPLES=none        # 'none' = all ~5k plans; or a number for a subset
# NUM_EPOCHS_SFT=2
# GRPO_MAX_SAMPLES=500
# NUM_GENERATIONS=4
# RETRY_WAIT=30           # seconds the watchdog waits before resuming after a crash
